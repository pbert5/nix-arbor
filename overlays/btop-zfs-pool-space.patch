+	bool zfs_collect_space_stats(const string& dataset, struct disk_info &disk) {
+		if (dataset.empty()) return false;
+
+		const string command = "/run/current-system/sw/bin/zfs list -Hp -o used,avail "
+			+ zfs_shell_quote(dataset)
+			+ " 2>/dev/null";
+		FILE* pipe = popen(command.c_str(), "r");
+		if (pipe == nullptr) return false;
+
+		unsigned long long used = 0;
+		unsigned long long avail = 0;
+		const int matched = fscanf(pipe, "%llu%llu", &used, &avail);
+		const int status = pclose(pipe);
+
+		if (matched != 2 or status != 0) return false;
+
+		const auto total = used + avail;
+		if (total > static_cast<unsigned long long>(numeric_limits<int64_t>::max())) {
+			return false;
+		}
+
+		disk.used = static_cast<int64_t>(used);
+		disk.free = static_cast<int64_t>(avail);
+		disk.total = static_cast<int64_t>(total);
+		if (disk.total != 0) {
+			disk.used_percent = round((double)disk.used * 100 / disk.total);
+			disk.free_percent = 100 - disk.used_percent;
+		} else {
+			disk.used_percent = 0;
+			disk.free_percent = 0;
+		}
+
+		return true;
+	}

+	string zfs_shell_quote(const string& value) {
+		string quoted = "'";
+		for (const auto& c : value) {
+			if (c == '\'') quoted += "'\\''";
+			else quoted += c;
+		}
+		quoted += "'";
+		return quoted;
+	}
